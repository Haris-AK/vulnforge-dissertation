@article{schreuders_security_nodate,
    title = {Security {Scenario} {Generator} ({SecGen}): {A} {Framework} for {Generating} {Randomly} {Vulnerable} {Rich}-scenario {VMs} for {Learning} {Computer} {Security} and {Hosting} {CTF} {Events}},
