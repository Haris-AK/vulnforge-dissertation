%%{init: {
  "theme": "neutral",
  "er": {
    "layoutDirection": "TB"
  },
  "themeVariables": {
    "fontFamily": "Times New Roman, serif",
    "fontSize": "13px"
  }
}}%%
erDiagram
    users {
        integer id            PK
        text    username      "UNIQUE NOT NULL"
        text    password_hash "NOT NULL"
        text    public_key    "SSH public key"
        integer created_at
    }

    sessions {
        integer id         PK
        integer user_id    FK
        text    token      "UNIQUE NOT NULL"
        integer expires_at
        integer created_at
    }

    challenges {
        integer id               PK
        integer user_id          FK
        text    title
        text    category
        text    difficulty
        text    hint
        text    flag             "NOT NULL"
        text    solution_summary "private"
        integer vmid
        text    ip
        text    status           "active|completed|expired|destroyed"
        integer expires_at
        integer completed_at
        integer created_at
    }

    messages {
        integer id           PK
        integer challenge_id FK
        text    role         "user | assistant"
        text    content
        integer created_at
    }

    users      ||--o{ sessions   : "has"
    users      ||--o{ challenges : "owns"
    challenges ||--o{ messages   : "has tutor history"
