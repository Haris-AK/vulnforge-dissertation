%%{init: {
  "flowchart": {
    "htmlLabels": true,
    "nodeSpacing": 30,
    "rankSpacing": 55,
    "curve": "basis"
  },
  "theme": "base",
  "themeVariables": {
    "fontFamily": "Times New Roman, serif",
    "fontSize": "13px",
    "primaryColor": "#ffffff",
    "primaryBorderColor": "#333333",
    "lineColor": "#333333",
    "clusterBkg": "#f8f8f8",
    "clusterBorder": "#999999"
  }
}}%%
flowchart TD
    subgraph SPEC["VulnerabilitySpec"]
        FILES["files[] — path · content · mode · owner · group"]
    end

    subgraph HOST["Proxmox Host — Ansible"]
        COPY["Ansible copy module — writes each file as opaque bytes"]
        STAGE["Temp staging dir — /tmp/vuln-inject-XXXX/"]
        COPY --> STAGE
    end

    subgraph CONTAINER["LXC Container"]
        PUSH["pct push vmid host-path container-path — LXC filesystem API"]
        CHOWN["pct exec — chown owner:group path"]
        FILES_IN["Files in place with correct paths and permissions"]
        PUSH --> CHOWN --> FILES_IN
    end

    subgraph CLEANUP["Cleanup"]
        RM["Staging dir removed regardless of outcome"]
    end

    FILES -->|"loop over files[]"| COPY
    STAGE -->|pct push per file| PUSH
    FILES_IN --> RM

    REJECTED["Rejected: pct exec -- bash -c 'echo content' — fails on quotes · dollars · newlines"]
    style REJECTED fill:#ffebee,stroke:#c62828,color:#b71c1c
