%%{init: {
  "flowchart": {
    "htmlLabels": true,
    "nodeSpacing": 36,
    "rankSpacing": 50,
    "curve": "basis"
  },
  "theme": "base",
  "themeVariables": {
    "fontFamily": "Times New Roman, serif",
    "fontSize": "13px",
    "primaryColor": "#ffffff",
    "primaryBorderColor": "#333333",
    "lineColor": "#333333",
    "clusterBkg": "#f8f8f8",
    "clusterBorder": "#999999"
  }
