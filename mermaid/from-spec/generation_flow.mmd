%%{init: {
  "flowchart": {
    "htmlLabels": true,
    "nodeSpacing": 28,
    "rankSpacing": 55,
    "curve": "basis"
  },
  "theme": "base",
  "themeVariables": {
    "fontFamily": "Times New Roman, serif",
    "fontSize": "13px",
    "primaryColor": "#ffffff",
    "primaryBorderColor": "#333333",
    "lineColor": "#333333",
    "clusterBkg": "#f8f8f8",
    "clusterBorder": "#999999"
  }
}}%%
flowchart TD
    START(["generateVulnerability — categoryId · difficulty · history"])

    subgraph SETUP["Setup"]
        FLAG["Generate flag — crypto.randomBytes 12 hex"]
        PROMPT["Build category prompt — variant · theme · exclusion list"]
        SCHEMA["Derive JSON Schema from Zod VulnerabilitySpecSchema"]
    end

    subgraph RETRY_LOOP["Retry Loop — max 3 attempts"]
        ATTEMPT{Within maxAttempts?}
        MODEL_CHAIN["Model fallback chain — primary → fallback-1 → fallback-2"]

        subgraph API_CALL["API Request"]
            CALL["POST /v1/messages — response_format: json_schema · temp 1.0"]
            FINISH{finishReason = stop?}
        end

        subgraph VALIDATION["Validation"]
            PARSE[JSON.parse response]
            ZOD{Zod safeParse}
            POLICY["validateGeneratedSpecPolicy — category · paths · commands · flag"]
            POLICY_OK{policy.valid?}
        end

        RETRY_ERR["Log failure — increment attempt"]
    end

    START --> FLAG --> PROMPT --> SCHEMA --> ATTEMPT
    ATTEMPT -->|Yes| MODEL_CHAIN --> CALL --> FINISH
    ATTEMPT -->|No| FATAL_ERR(["Throw — generation failed"])
    FINISH -->|No| RETRY_ERR
    FINISH -->|Yes| PARSE --> ZOD
    ZOD -->|fail| RETRY_ERR
    ZOD -->|pass| POLICY --> POLICY_OK
    POLICY_OK -->|No| RETRY_ERR
    POLICY_OK -->|Yes| SUCCESS(["Return VulnerabilitySpec + flag"])
    RETRY_ERR --> ATTEMPT
