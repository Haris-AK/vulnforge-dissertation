graph TB
    subgraph Client["Browser / Client"]
        UI[React Dashboard]
        SSE[SSE Stream Consumer]
    end

    subgraph NextJS["Next.js Application — Bun runtime"]
        MW[Middleware — Route Protection]

        subgraph Routes["API Routes"]
            API_AUTH["/api/auth/* — Login · Signup · Session"]
            API_CHALLENGES["/api/challenges/* — Launch · Submit · History"]
            API_CHAT["/api/chat — AI Tutor"]
        end

        subgraph Lib["Core Library"]
            GEN["openrouter.ts — Vulnerability Generator"]
            ANS["ansible-runner.ts — Orchestration Client"]
            VER["verification-runner.ts — Verification Engine"]
            AUTH["auth.ts — Session Management"]
        end

        DB[(SQLite — Drizzle ORM)]
    end

    subgraph LLM["LLM Layer — OpenRouter"]
        OR[OpenRouter Gateway]
        subgraph Models["Model Chain"]
            GM[Gemini 3.1 Pro — primary]
            GM2[Gemini 2.5 Pro — fallback 1]
            KI[Kimi K2 — fallback 2]
        end
    end

    subgraph Proxmox["Proxmox VE Host"]
        subgraph Automation["Ansible Automation"]
            ANS_PB["Playbooks — deploy · inject · verify · destroy"]
            PCT[pct — LXC CLI]
        end
        REAPER[TTL Reaper — cron]

        subgraph LXC["LXC Containers"]
            C1["Container N — tag: vulnforge — student user"]
            C2[Container M — ...]
        end
    end

    UI -->|HTTP| MW
    MW --> API_AUTH & API_CHALLENGES & API_CHAT
    SSE -.->|EventSource| API_CHALLENGES

    API_CHALLENGES --> GEN & ANS & VER
    API_AUTH --> AUTH
    API_CHAT --> GEN

    GEN -->|json_schema| OR
    OR --> GM
    OR -.-> GM2
    OR -.-> KI

    ANS & VER -->|execFile / SSH| ANS_PB
    ANS_PB --> PCT --> C1 & C2
    REAPER -.->|pct stop| C1 & C2

    AUTH & API_CHALLENGES & API_CHAT --> DB

    %% Force LLM above Proxmox
    KI ~~~ ANS_PB
