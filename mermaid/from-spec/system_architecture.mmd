graph TB
    subgraph Client["Browser / Client"]
        UI[React Dashboard]
        SSE[SSE Stream Consumer]
    end

    subgraph NextJS["Next.js Application — Bun runtime"]
        MW[Middleware — Route Protection]

        subgraph Routes["API Routes"]
            API_AUTH["/api/auth/*\nLogin · Signup · Session"]
            API_CHALLENGES["/api/challenges/*\nLaunch · Submit · History"]
            API_CHAT["/api/chat\nAI Tutor"]
        end

        subgraph Lib["Core Library"]
            GEN[openrouter.ts\nVulnerability Generator]
            ANS[ansible-runner.ts\nOrchestration Client]
            VER[verification-runner.ts\nVerification Engine]
            AUTH[auth.ts\nSession Management]
        end

        DB[(SQLite — Drizzle ORM)]
    end

    subgraph LLM["LLM Layer — OpenRouter"]
        OR[OpenRouter Gateway]
        subgraph Models["Model Chain"]
            GM[Gemini 3.1 Pro\nprimary]
            GM2[Gemini 2.5 Pro\nfallback 1]
            KI[Kimi K2\nfallback 2]
        end
    end

    subgraph Proxmox["Proxmox VE Host"]
        subgraph Automation["Ansible Automation"]
            ANS_PB[Playbooks\ndeploy · inject · verify · destroy]
            PCT[pct — LXC CLI]
        end
        REAPER[TTL Reaper — cron / shell]

        subgraph LXC["LXC Containers"]
            C1[Container VMID=N\ntag: vulnforge — student user]
            C2[Container VMID=M — ...]
        end
    end

    UI -->|HTTP| MW
    MW --> API_AUTH
    MW --> API_CHALLENGES
    MW --> API_CHAT
    SSE -.->|EventSource| API_CHALLENGES

    API_CHALLENGES --> GEN
    API_CHALLENGES --> ANS
    API_CHALLENGES --> VER
    API_AUTH --> AUTH
    API_CHAT --> GEN

    GEN -->|json_schema + system prompt| OR
    OR --> GM
    OR -.-> GM2
    OR -.-> KI

    ANS -->|execFile / SSH| ANS_PB
    VER -->|execFile / SSH| ANS_PB
    ANS_PB --> PCT
    PCT --> C1
    PCT --> C2

    REAPER -->|pct shutdown / stop| C1
    REAPER -->|pct shutdown / stop| C2

    AUTH --> DB
    API_CHALLENGES --> DB
    API_CHAT --> DB
