%%{init: {
  "flowchart": {
    "htmlLabels": true,
    "nodeSpacing": 28,
    "rankSpacing": 55,
    "curve": "basis"
  },
  "theme": "base",
  "themeVariables": {
    "fontFamily": "Times New Roman, serif",
    "fontSize": "13px",
    "primaryColor": "#ffffff",
    "primaryBorderColor": "#333333",
    "lineColor": "#333333",
    "clusterBkg": "#f8f8f8",
    "clusterBorder": "#999999"
  }
}}%%
flowchart TD
    START(["verifyInjectedChallenge — vmid · ip · flag · spec · mode"])

    subgraph SELECTION["Check Selection"]
        SELECT{mode?}
        HC_FP["health + flag_protection checks"]
        HC_FP_EX["health + flag_protection + exploit checks"]
        SELECT -->|health| HC_FP
        SELECT -->|full| HC_FP_EX
    end

    subgraph PREPARATION["Preparation"]
        SUBST["Substitute placeholders — TARGET_IP · TARGET_URL · FLAG · VMID"]
        WRITE["Write checks to .tmp/verify-vmid-UUID.json"]
        PLAYBOOK["ansible-playbook verify-vulnerability.yml"]
    end

    subgraph DISPATCH["Per-command Dispatch"]
        CTX{context?}
        ROOT["pct exec — bash as root"]
        STUDENT["pct exec — bash as student"]
        HTTP["curl from Proxmox host"]
        CTX -->|container_root| ROOT
        CTX -->|container_student| STUDENT
        CTX -->|external_http| HTTP
    end

    subgraph EVALUATE["Evaluate per result"]
        CHECKS["Check exit code · stdout contains · stdout excludes · flag recovered"]
    end

    subgraph GROUP["Group Results"]
        HP[healthPassed]
        FP[flagProtectionPassed]
        EP["exploitPassed — full mode only"]
    end

    START --> SELECT
    HC_FP & HC_FP_EX --> SUBST --> WRITE --> PLAYBOOK --> CTX
    ROOT & STUDENT & HTTP --> CHECKS
    CHECKS --> HP & FP & EP --> RESULT

    RESULT{success?}
    RESULT -->|Yes| OK(["VerificationResult: success"])
    RESULT -->|No| FAIL(["VerificationResult: failed — per-command failureReason"])

    WRITE -.->|cleanup| DEL["unlink checks JSON"]
